"""
EXPERIMENT 6: Text Analytics - Spam Filter
Binary classification of SMS messages as spam or ham
"""

import numpy as np
import pandas as pd
import re
import matplotlib.pyplot as plt
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.naive_bayes import MultinomialNB
from sklearn.metrics import accuracy_score, confusion_matrix, classification_report

print("="*60)
print("TEXT ANALYTICS - SPAM FILTER")
print("="*60)

# Create synthetic dataset
np.random.seed(42)
n_samples = 500

# Spam messages
spam_messages = [
    "WINNER!! You've won $1000 cash! Click here to claim",
    "URGENT! Your account has been compromised. Verify now",
    "Congratulations! You're eligible for a free iPhone",
    "Limited time offer! Buy now and get 50% off",
    "You have won a lottery! Send money to claim prize",
    "FREE entry to win a vacation! Text WIN to 12345",
    "Your subscription will expire. Renew immediately",
    "Claim your prize now! This is your last chance",
    "Earn money from home! Work from anywhere",
    "Dear customer, your account needs verification"
]

# Ham (normal) messages
ham_messages = [
    "Hey, how are you? Want to grab lunch tomorrow?",
    "Can you please send me the meeting notes?",
    "Don't forget about the project deadline on Friday",
    "Thanks for your help with the presentation",
    "What time is the team meeting scheduled?",
    "I'll be late for the appointment, sorry",
    "Please review the attached document",
    "Great job on the quarterly report!",
    "Let's catch up over coffee sometime",
    "The weather is beautiful today"
]

# Generate dataset
spam_texts = np.random.choice(spam_messages, n_samples//2, replace=True)
ham_texts = np.random.choice(ham_messages, n_samples//2, replace=True)

# Add some variation
for i in range(len(spam_texts)):
    if np.random.random() < 0.3:
        spam_texts[i] += " !!!"
    if np.random.random() < 0.2:
        spam_texts[i] = spam_texts[i].upper()

messages = np.concatenate([spam_texts, ham_texts])
labels = np.concatenate([np.ones(n_samples//2), np.zeros(n_samples//2)])

# Create DataFrame
df = pd.DataFrame({'Message': messages, 'Spam': labels})
print("Dataset Info:")
print(df.head(10))
print(f"\nClass distribution:")
print(df['Spam'].value_counts())
print(f"Spam: {df['Spam'].sum()}, Ham: {len(df) - df['Spam'].sum()}")

# Text preprocessing
def preprocess_text(text):
    text = text.lower()
    text = re.sub(r'[^a-zA-Z\s]', '', text)
    text = re.sub(r'\s+', ' ', text).strip()
    return text

df['Clean_Message'] = df['Message'].apply(preprocess_text)
print("\nPreprocessing example:")
print(f"Original: {df['Message'].iloc[0]}")
print(f"Cleaned: {df['Clean_Message'].iloc[0]}")

# Split data
X_train, X_test, y_train, y_test = train_test_split(
    df['Clean_Message'], df['Spam'], test_size=0.2, random_state=42
)

# Vectorize text (TF-IDF)
vectorizer = TfidfVectorizer(max_features=1000, stop_words='english')
X_train_vec = vectorizer.fit_transform(X_train)
X_test_vec = vectorizer.transform(X_test)

print(f"\nFeature matrix shape: {X_train_vec.shape}")

# Train classifier
classifier = MultinomialNB()
classifier.fit(X_train_vec, y_train)

# Predictions
y_pred = classifier.predict(X_test_vec)

# Evaluation
accuracy = accuracy_score(y_test, y_pred)
print("\n" + "="*60)
print("MODEL PERFORMANCE")
print("="*60)
print(f"Accuracy: {accuracy*100:.2f}%")
print("\nClassification Report:")
print(classification_report(y_test, y_pred, target_names=['Ham', 'Spam']))

# Confusion Matrix
cm = confusion_matrix(y_test, y_pred)

# Visualization
fig, axes = plt.subplots(1, 2, figsize=(10, 4))

# Confusion Matrix
axes[0].imshow(cm, interpolation='nearest', cmap='Blues')
axes[0].set_title('Confusion Matrix')
axes[0].set_xticks([0, 1])
axes[0].set_yticks([0, 1])
axes[0].set_xticklabels(['Ham', 'Spam'])
axes[0].set_yticklabels(['Ham', 'Spam'])
axes[0].set_xlabel('Predicted')
axes[0].set_ylabel('Actual')

for i in range(2):
    for j in range(2):
        axes[0].text(j, i, str(cm[i, j]), ha='center', va='center', fontsize=14)

# Feature importance (top words)
feature_names = vectorizer.get_feature_names_out()
top_features = np.argsort(classifier.feature_log_prob_[1])[-10:]

axes[1].barh(range(10), classifier.feature_log_prob_[1][top_features])
axes[1].set_yticks(range(10))
axes[1].set_yticklabels(feature_names[top_features])
axes[1].set_title('Top 10 Words Indicating Spam')
axes[1].set_xlabel('Log Probability')

plt.tight_layout()
plt.show()

# Test custom messages
test_messages = [
    "Congratulations! You've won a free gift card",
    "Hey, can we meet tomorrow at 3 PM?",
    "URGENT: Your account will be suspended",
    "Thanks for your email, I'll get back to you soon"
]

print("\n" + "="*60)
print("TESTING CUSTOM MESSAGES")
print("="*60)
for msg in test_messages:
    clean_msg = preprocess_text(msg)
    msg_vec = vectorizer.transform([clean_msg])
    prediction = classifier.predict(msg_vec)[0]
    prob = classifier.predict_proba(msg_vec)[0]
    print(f"\nMessage: {msg}")
    print(f"Prediction: {'SPAM' if prediction == 1 else 'HAM'}")
    print(f"Confidence: {max(prob)*100:.1f}%")

print("\n✓ Spam Filter implemented!")

# df.to_csv('complete_sales_data.csv', index=False)

print("\n10. KEY INSIGHTS")
print("="*40)
print(f"📊 Total Orders: {len(df)}")
print(f"💰 Total Revenue: ${total_revenue:,.2f}")
print(f"📈 Average Order: ${average_order:.2f}")
print(f"🏆 Best Category: {category_stats['Total_Amount']['sum'].idxmax()}")
print(f"💳 Most Used Payment: {payment_stats['count'].idxmax()}")
print(f"📦 Return Rate: {(len(returns)/len(df))*100:.2f}%")

print("\n✓ Data Analysis with Pandas & NumPy completed!")
